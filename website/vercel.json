{
  "rewrites": [
    { "source": "/new", "destination": "/new.html" },
    { "source": "/live", "destination": "/live.html" },
    { "source": "/live-activity", "destination": "/live-activity.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/sign-in", "destination": "/sign-in.html" },
    { "source": "/set-password", "destination": "/set-password.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/portal/dashboard", "destination": "/portal-dashboard.html" },
    { "source": "/portal", "destination": "/portal-dashboard.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/special-ops-calendar", "destination": "/special-ops-calendar.html" },
    { "source": "/vsl", "destination": "/vsl.html" },
    { "source": "/vsl-sales-page", "destination": "/vsl-sales-page.html" },
    { "source": "/launch", "destination": "/launch.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/start", "destination": "/start.html" },
    { "source": "/report", "destination": "/report.html" },
    { "source": "/welcome", "destination": "/welcome.html" },
    { "source": "/checkout", "destination": "/checkout.html" },
    { "source": "/cancel", "destination": "/cancel.html" },
    { "source": "/dashboard/:path*", "destination": "/dashboard.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/live/:path*", "destination": "/dashboard.html" }
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.+\\.png|.+\\.jpg|.+\\.ico|.+\\.svg|.+\\.webp)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "trailingSlash": false
}
